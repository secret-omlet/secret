local function TurnOffAll()
    Core.LevelUpEnabled = false; Core.BossFarmEnabled = false; Core.KillAuraEnabled = false
    Target.ChestStopSignal = true; Core.ChestFarmEnabled = false; FruitPriorityActive = false; IsCollectingFruit = false
    Extra.Set("AutoSeaEnabled", false); Extra.Set("IslandTeleportEnabled", false)
    FSState.Active = false; FSState.Phase = "Idle"; FSState.CurrentStyle = nil; FSState.TargetMob = nil
    SHState.Active = false; SHState.Phase = "Idle"; SHState.TargetMob = nil
