local function CollectAllAvailableChests()
    while Core.ChestFarmEnabled and not Target.ChestStopSignal do
        -- توقف چست در صورت داشتن چالیس
        if StopChestOnChalice and HasGodsChalice() then
            Target.ChestStopSignal = true
            Core.ChestFarmEnabled = false
            if Target.ChestActiveTween then Target.ChestActiveTween:Cancel(); Target.ChestActiveTween = nil end
            Target.Chest = nil
            WindUI:Notify({Title="اتو چست متوقف شد!", Content="شما God's Chalice گرفتید.", Duration=5})
            return
        end

        local chest = GetNearestChest(); if not chest then return end
        Target.Chest = chest; local StartT = tick()
        if not ChestFailedAttempts[chest] then ChestFailedAttempts[chest] = 0 end
        ChestFailedAttempts[chest] = ChestFailedAttempts[chest] + 1
        if ChestFailedAttempts[chest] > Settings.ChestMaxAttempts then ChestBuggedList[chest] = true; Target.Chest = nil; task.wait(0.1); continue end

        while Core.ChestFarmEnabled and not Target.ChestStopSignal and chest and chest.Parent and HasTouchInterest(chest) do
            if Target.ChestStopSignal or (Core.DoughKingEnabled and HasGodsChalice()) then if Target.ChestActiveTween then Target.ChestActiveTween:Cancel(); Target.ChestActiveTween=nil end; Target.Chest=nil; return end
            
            -- بررسی مجدد داخل حلقه
            if StopChestOnChalice and HasGodsChalice() then
                Target.ChestStopSignal = true
                Core.ChestFarmEnabled = false
                if Target.ChestActiveTween then Target.ChestActiveTween:Cancel(); Target.ChestActiveTween = nil end
                Target.Chest = nil
                WindUI:Notify({Title="اتو چست متوقف شد!", Content="شما God's Chalice گرفتید.", Duration=5})
                return
            end

            local Root = Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart"); if not Root then break end
            local Dest = GetChestCFrame(chest); if not Dest then break end
            local Dist = (Root.Position - Dest.Position).Magnitude
            if Dist < 6 then
                if Target.ChestActiveTween then Target.ChestActiveTween:Cancel() end
                Root.CFrame = Dest; task.wait(Settings.ChestCollectionDelay)
                if not HasTouchInterest(chest) then TotalChestsCollected=TotalChestsCollected+1; ChestFailedAttempts[chest]=nil end
                break
            else
                if Target.ChestActiveTween then Target.ChestActiveTween:Cancel() end
                Target.ChestActiveTween = TweenService:Create(Root, TweenInfo.new(Dist<25 and 0.1 or Dist/Settings.FlightSpeed, Enum.EasingStyle.Linear), {CFrame = Dest}); Target.ChestActiveTween:Play()
            end
            if (tick() - StartT) > Settings.ChestMaxTravelTime then break end
            task.wait(0.2)
        end
        Target.Chest = nil; task.wait(0.1)
    end
end

