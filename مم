local function GetActiveFarmMode()
    if Extra.Get("IsDoingPriorityTask") then return "PriorityTask" end
    if Extra.Get("AutoTushita") and Extra.Get("TushitaPhase") ~= "Idle" then return "PriorityTask" end
    if FruitPriorityActive then return "Fruit" end
    if Core.DoughKingEnabled and Core.DoughKingPhase~="Idle" and Core.DoughKingPhase~="WaitingForChalice" then return "DoughKing" end
    if SHState.Active then return "Superhuman" end
    if RaidConfig.RaidEnabled then return "Raid" end
    if Core.KillAuraEnabled then return "KillAura" end 
    if Core.LevelUpEnabled then return "LevelUp" end
    if Core.BossFarmEnabled then return "BossFarm" end
    if Core.ChestFarmEnabled then return "Chest" end
    if Extra.Get("AutoSeaEnabled") then return "AutoSea" end
    if Extra.Get("IslandTeleportEnabled") then return "IslandTeleport" end
    if FSState.Active then return "FightingStyle" end
    return Core.FarmMode
end

