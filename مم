local CachedDealerFruits = "در حال محاسبه..."
local LastDealerCheckCycle = -1
task.spawn(function()
    while task.wait(5) do
        local cCycle = math.floor(os.time() / 14400)
        if LastDealerCheckCycle ~= cCycle then
            pcall(function()
                local stock = ReplicatedStorage.Remotes.CommF_:InvokeServer("GetFruits", false)
                if type(stock) == "table" then
                    local onSale = {}
                    for _, f in pairs(stock) do if f.OnSale then table.insert(onSale, getCleanName(f.Name)) end end
                    CachedDealerFruits = table.concat(onSale, " ، ")
                    if CachedDealerFruits == "" then CachedDealerFruits = "هیچ فروتی موجود نیست" end
                    LastDealerCheckCycle = cCycle
                end
            end)
        end
    end
end)

task.spawn(function()
    while task.wait(1.5) do
        pcall(function()
            local actionStr = GetActiveFarmMode()
            local meleeName, masteryLevel = GetMeleeMastery(nil)
            local masteryStr = meleeName .. " | مستری: " .. tostring(masteryLevel)
            local bossesStr = ""
            for _, d in ipairs(BossDatabase) do if IsBossSpawned(d.Mob) then bossesStr = bossesStr .. d.Mob .. " ، " end end
            if bossesStr == "" then bossesStr = "هیچ باسی نیست" else bossesStr = string.sub(bossesStr, 1, -4) end

            local checkTime = ReplicatedStorage.Remotes.CommF_:InvokeServer("Cousin", "CheckTime", "DLCBoxData")
            local canBuy = ReplicatedStorage.Remotes.CommF_:InvokeServer("Cousin", "CheckCanBuyType", "DLCBoxData")
            local timeReady = (checkTime == true or tostring(checkTime):lower():find("true") or checkTime == 0 or tostring(checkTime):lower():find("ready"))
            local moneyReady = (canBuy == 1 or canBuy == true or tostring(canBuy) == "1" or tostring(canBuy) == "true")
            local gachaStr = ""
            if timeReady then gachaStr = "آماده رول!" else local cleanTime = tostring(checkTime):match("%d+:[%d:]+"); if cleanTime then gachaStr = "مانده: " .. cleanTime else gachaStr = "محاسبه..." end end
            if not moneyReady then gachaStr = gachaStr .. " | ❌ پول کافی نیست" end

            local fruitsStr = ""
            for _, v in pairs(Workspace:GetChildren()) do if (v:IsA("Tool") or v:IsA("Model")) and string.find(v.Name,"Fruit") and not string.find(v.Name,"Dealer") and not string.find(v.Name,"Gacha") and not string.find(v.Name,"Blox Fruit") then fruitsStr = fruitsStr .. getCleanName(v.Name) .. " ، " end end
            if fruitsStr == "" then fruitsStr = "میوه‌ای روی زمین نیست" else fruitsStr = string.sub(fruitsStr, 1, -4) end

            UI.StatusPanel:SetDesc(
                "🔰 لول فعلی: " .. GetMyLevel() ..
                "\n💵 پول: $" .. formatNumber(GetPlayerBeli()) ..
                "\n💎 فرگمنت: " .. formatNumber(GetPlayerFragments()) ..
                "\n🎣 ماهی گرفته شده: " .. (Extra.Get("TotalFishCaught") or 0) ..
                "\n⚙️ درحال انجام: " .. actionStr ..
                "\n🎁 چست جمع شده: " .. TotalChestsCollected ..
                "\n🎰 گاچا: " .. gachaStr ..
                "\n🏪 دیلر: " .. CachedDealerFruits ..
                "\n💀 باس‌ها: " .. bossesStr ..
                "\n🍎 روی زمین: " .. fruitsStr
            )
        end)
    end
end)

