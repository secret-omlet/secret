local LastFastTeleport = 0
local function SmartTween(root, targetCFrame, activeTween)
    if not root then return nil end
    local myPos = root.Position; local targetPos = targetCFrame.Position; local dist = (myPos - targetPos).Magnitude
    if dist < 10 then root.CFrame = targetCFrame; if activeTween then activeTween:Cancel() end; return nil end

    if tick() - LastFastTeleport > 3 then
        local teleported = false
        if Sea == 1 then
            local distFishman = (myPos - Vector3.new(61163, 11, 1819)).Magnitude
            local targetDistFishman = (targetPos - Vector3.new(61163, 11, 1819)).Magnitude
            local distSky1, myDistSky1 = (targetPos - Vector3.new(-4607, 874, -1667)).Magnitude, (myPos - Vector3.new(-4607, 874, -1667)).Magnitude
            local distSky2, myDistSky2 = (targetPos - Vector3.new(-7894, 5547, -380)).Magnitude, (myPos - Vector3.new(-7894, 5547, -380)).Magnitude
            if distFishman > 3000 and targetDistFishman < 3000 then ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(61163.85, 11.68, 1819.78)); teleported = true
            elseif distFishman < 3000 and targetDistFishman > 3000 then ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(3864.69, 6.74, -1926.21)); teleported = true
            elseif targetDistFishman > 3000 then
                if distSky2 < 2000 and myDistSky2 > 2000 then ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(-7894.61, 5547.14, -380.29)); teleported = true
                elseif distSky1 < 2000 and myDistSky1 > 2000 then ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(-4607.82, 874.39, -1667.55)); teleported = true end
            end
        elseif Sea == 2 then
            local distCursed = (myPos - Vector3.new(923, 126, 32852)).Magnitude
            local targetDistCursed = (targetPos - Vector3.new(923, 126, 32852)).Magnitude
            if distCursed > 3000 and targetDistCursed < 3000 then ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(923.21, 126.97, 32852.83)); teleported = true
            elseif distCursed < 3000 and targetDistCursed > 3000 then ReplicatedStorage.Remotes.CommF_:InvokeServer("requestEntrance", Vector3.new(-6508.55, 89.03, -132.84)); teleported = true end
        end
        if teleported then if activeTween then activeTween:Cancel() end; LastFastTeleport = tick(); task.wait(1.5); return nil end
    end

    local useCFrame = targetCFrame
    if dist > 300 and myPos.Y > -500 and targetPos.Y > -500 then useCFrame = targetCFrame * CFrame.new(0, 40, 0) end
    if activeTween then activeTween:Cancel() end
    local tween = TweenService:Create(root, TweenInfo.new(dist / Settings.FlightSpeed, Enum.EasingStyle.Linear), {CFrame = useCFrame})
    tween:Play(); return tween
end

local function GetMeleeMastery(styleName)
    local function checkTool(tool)
        if tool and tool:IsA("Tool") and tool.ToolTip == "Melee" then
            if styleName then if string.lower(tool.Name):find(string.lower(styleName)) then local lvl = tool:FindFirstChild("Level"); return tool.Name, lvl and lvl.Value or 0 end
            else local lvl = tool:FindFirstChild("Level"); return tool.Name, lvl and lvl.Value or 0 end
        end; return nil, 0
    end
    if Plr.Character then for _, tool in pairs(Plr.Character:GetChildren()) do local n, v = checkTool(tool); if n then return n, v end end end
    for _, tool in pairs(Plr.Backpack:GetChildren()) do local n, v = checkTool(tool); if n then return n, v end end
    return "هیچ میلی پیدا نشد", 0
end

local function FSIsEnemyValid(E) if not E or not E.Parent then return false end; local h = E:FindFirstChild("Humanoid"); if not h or h.Health <= 0 then return false end; return E:FindFirstChild("HumanoidRootPart") ~= nil end
local function FSFindEnemy(mobName)
    local root = Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    local fm, md = nil, math.huge; local enemies = Workspace:FindFirstChild("Enemies")
    if enemies then for _, v in pairs(enemies:GetChildren()) do pcall(function() if string.find(v.Name, mobName) and FSIsEnemyValid(v) then local d = (root.Position - v.HumanoidRootPart.Position).Magnitude; if d < md then md = d; fm = v end end end) end end
    return fm
end

