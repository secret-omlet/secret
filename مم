    Extra.Set("AutoEliteHunter", false); Extra.Set("AutoYama", false); Extra.Set("TryLuckYama", false)
    Extra.Set("AutoTushita", false)
    
    AutoLevelUp.Stop()
    AutoRaid.Stop()
    
    Target.Current = nil; CurrentBossData = nil; Target.Chest = nil; CurrentFruit = nil
    Core.FarmMode = "None"
    pcall(function() if Target.ExpandedEnemy then CleanupExpandedHead(Target.ExpandedEnemy); Target.ExpandedEnemy = nil end end)
    pcall(function() if Target.ActiveTween then Target.ActiveTween:Cancel(); Target.ActiveTween = nil end end)
    pcall(function() if Target.ChestActiveTween then Target.ChestActiveTween:Cancel(); Target.ChestActiveTween = nil end end)
    Extra.CancelTweens()
    task.delay(0.1, function() Target.ChestStopSignal = false end)
end

